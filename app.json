{
  "expo": {
    "name": "Utopia",
    "slug": "utopia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#067D5A"
    },
    "android": {
      "package": "com.nabib.utopia",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Utopia uses your location to show friends near you on campus."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Utopia needs photo access so you can share posts.",
          "cameraPermission": "Utopia needs camera access so you can share posts."
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-audio",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "1c10fc29-22e7-4807-b071-9e106cad204b"
      }
    }
  }
}
